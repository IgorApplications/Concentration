<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:background="#D9D6CE"
        android:layout_height="match_parent"
        tools:context=".activities.ListActivity">

    <LinearLayout
            android:id="@+id/topProfile"
            android:layout_width="80dp"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="18dp"
            android:layout_marginEnd="20dp"
            android:padding="6dp"
            android:background="@drawable/bg_profile_counter"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

        <TextView
                android:id="@+id/profileCount"
                android:text="0"
                android:textColor="#FFF"
                android:textSize="16sp"
                android:layout_marginEnd="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        <ImageView
                android:src="@drawable/ic_profile"
                app:tint="#FFF"
                android:layout_width="18dp"
                android:layout_height="18dp"/>

    </LinearLayout>

    <LinearLayout
            android:id="@+id/header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:orientation="vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

        <TextView
                android:id="@+id/greetings"
                android:text="Ваш список дел на сегодня"
                android:textSize="17sp"
                android:textStyle="normal"
                android:textColor="#222"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        <TextView
                android:text="Успехов в выполнении!"
                android:textSize="14sp"
                android:textColor="#666"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        <TextView
                android:id="@+id/dayAndMonth"
                android:text="1 Января"
                android:textSize="16sp"
                android:textColor="#222"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"/>

    </LinearLayout>

    <View
            android:id="@+id/dividerBottom"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="#BDB8AF"
            app:layout_constraintTop_toBottomOf="@id/header"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>

    <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/taskList"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:padding="16dp"
            android:overScrollMode="never"
            android:scrollbars="none"
            android:clipToPadding="false"
            app:layout_constraintTop_toBottomOf="@id/header"
            app:layout_constraintBottom_toTopOf="@id/bottomMenu"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    <ImageButton
            android:id="@+id/addTask"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_plus"
            android:background="@drawable/bg_add_button"
            android:layout_margin="20dp"
            app:layout_constraintBottom_toTopOf="@id/bottomMenu"
            app:layout_constraintEnd_toEndOf="parent" app:tint="#FFFFFF"/>

    <LinearLayout
            android:id="@+id/bottomMenu"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:background="#E8E6DF"
            app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
                android:orientation="vertical"
                android:gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="18dp">

            <ImageButton
                    android:id="@+id/calendar"
                    android:src="@drawable/ic_calendar"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="#000"
                    android:layout_width="40dp"
                    android:layout_height="40dp"/>

            <TextView
                    android:text="Привычки"
                    android:textColor="#222"
                    android:textSize="12sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

        </LinearLayout>

        <LinearLayout
                android:orientation="vertical"
                android:gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="18dp">

            <ImageButton
                    android:id="@+id/home"
                    android:src="@drawable/ic_home"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="#000"
                    android:layout_width="40dp"
                    android:layout_height="40dp"/>

            <TextView
                    android:text="Главная"
                    android:textColor="#222"
                    android:textSize="12sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

        </LinearLayout>

        <LinearLayout
                android:orientation="vertical"
                android:gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="18dp"
                android:translationY="-6dp">

            <FrameLayout
                    android:layout_width="60dp"
                    android:layout_height="60dp">

                <View
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:background="@drawable/bg_home"/>

                <ImageButton
                        android:id="@+id/list"
                        android:src="@drawable/ic_list"
                        app:tint="#FFF"
                        android:background="@android:color/transparent"
                        android:layout_gravity="center"
                        android:layout_width="36dp"
                        android:layout_marginBottom="5dp"
                        android:layout_height="36dp"/>

            </FrameLayout>

            <TextView
                    android:text="Список дел"
                    android:textColor="#FFF"
                    android:textSize="12sp"
                    android:layout_marginTop="-18dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

        </LinearLayout>

        <LinearLayout
                android:orientation="vertical"
                android:gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="18dp">

            <ImageButton
                    android:id="@+id/profile"
                    android:src="@drawable/ic_profile"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="#000"
                    android:layout_width="40dp"
                    android:layout_height="40dp"/>

            <TextView
                    android:text="Профиль"
                    android:textColor="#222"
                    android:textSize="12sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>