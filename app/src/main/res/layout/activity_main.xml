<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:background="#D9D6CE"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <LinearLayout
            android:id="@+id/topProfile"
            android:layout_width="80dp"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="18dp"
            android:layout_marginEnd="20dp"
            android:padding="6dp"
            android:background="@drawable/bg_profile_counter"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

        <TextView
                android:id="@+id/profileCount"
                android:text="0"
                android:textColor="#FFF"
                android:textSize="16sp"
                android:layout_marginEnd="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        <ImageView
                android:src="@drawable/ic_profile"
                app:tint="#FFF"
                android:layout_width="18dp"
                android:layout_height="18dp"/>

    </LinearLayout>

    <LinearLayout
            android:id="@+id/header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:orientation="vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

        <TextView
                android:id="@+id/greetings"
                android:text="Приветствую, Влад!"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#222"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        <TextView
                android:text="Хорошего дня!"
                android:textSize="14sp"
                android:textColor="#666"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

    </LinearLayout>

    <LinearLayout
            android:id="@+id/filterRow"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/header"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="16dp">

        <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/filterToday"
                android:text="Сегодня"
                android:textColor="#FFF"
                android:background="@drawable/bg_filter_today"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:layout_marginEnd="8dp"
                android:layout_height="40dp"
                android:layout_width="wrap_content"/>

        <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/filterTomorrow"
                android:text="Завтра"
                android:textColor="#000"
                android:background="@drawable/bg_filter_outline"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:layout_marginEnd="8dp"
                android:layout_height="40dp"
                android:layout_width="wrap_content"/>

        <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/filterMonth"
                android:text="Весь месяц"
                android:textColor="#000"
                android:background="@drawable/bg_filter_outline"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:layout_marginEnd="8dp"
                android:layout_height="40dp"
                android:layout_width="wrap_content"/>

        <ImageButton
                android:id="@+id/addButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_circle_outline_small"
                android:src="@drawable/ic_plus"
                app:tint="#000"
                android:scaleType="center"/>

    </LinearLayout>

    <LinearLayout
            android:id="@+id/dateBlock"
            android:orientation="horizontal"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/filterRow"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

        <LinearLayout
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

            <TextView
                    android:id="@+id/dayWeek"
                    android:text="Понедельник"
                    android:textSize="16sp"
                    android:textColor="#222"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            <TextView
                    android:id="@+id/dayMonth"
                    android:text="1"
                    android:textSize="64sp"
                    android:textStyle="bold"
                    android:textColor="#000"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            <TextView
                    android:id="@+id/month"
                    android:text="ЯНВАРЬ"
                    android:textSize="28sp"
                    android:textColor="#000"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

        </LinearLayout>

    </LinearLayout>

    <View
            android:id="@+id/dividerVertical"
            android:layout_width="1dp"
            android:layout_height="120dp"
            android:background="#BDB8AF"
            app:layout_constraintStart_toEndOf="@id/dateBlock"
            app:layout_constraintTop_toTopOf="@id/dateBlock"
            android:layout_marginStart="24dp"/>

    <LinearLayout
            android:id="@+id/concentrationBlock"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="40dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/dateBlock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

        <ImageButton
                android:id="@+id/concentrationButton"
                android:layout_marginTop="10dp"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:background="@drawable/bg_circle_outline_big"
                android:src="@drawable/ic_plus"
                android:scaleType="center"
                android:backgroundTint="@null"
                app:tint="#000"/>
        <TextView
                android:text="Концентрация"
                android:textSize="14sp"
                android:textColor="#222"
                android:layout_marginTop="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

    </LinearLayout>

    <View
            android:id="@+id/dividerBottom"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="#BDB8AF"
            app:layout_constraintTop_toBottomOf="@id/dateBlock"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"/>


    <androidx.constraintlayout.motion.widget.MotionLayout
            android:id="@+id/bottomMenu"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:background="#E8E6DF"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layoutDescription="@xml/bottom_motion">

        <View
                android:id="@+id/homeCircle"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/bg_home"

                app:layout_constraintStart_toStartOf="@id/motion_layout_2"
                app:layout_constraintEnd_toEndOf="@id/motion_layout_2"
                app:layout_constraintTop_toTopOf="@id/motion_layout_2"
                app:layout_constraintBottom_toBottomOf="@id/motion_layout_2"/>

        <LinearLayout
                android:id="@+id/motion_layout_1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"

                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/motion_layout_2"

                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"

                app:layout_constraintHorizontal_chainStyle="packed"
                android:layout_marginEnd="28dp">

            <ImageButton
                    android:id="@+id/calendar"
                    android:src="@drawable/ic_calendar"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    app:tint="#222"/>

            <TextView
                    android:text="Привычки"
                    android:textColor="#222"
                    android:textSize="12sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

        </LinearLayout>

        <LinearLayout
                android:id="@+id/motion_layout_2"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"

                app:layout_constraintStart_toEndOf="@id/motion_layout_1"
                app:layout_constraintEnd_toStartOf="@id/motion_layout_3"

                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"

                android:layout_marginEnd="28dp"
                android:translationY="-6dp">


            <ImageButton
                    android:id="@+id/home"
                    android:src="@drawable/ic_home"
                    android:background="@android:color/transparent"
                    android:layout_gravity="center"
                    android:layout_width="36dp"
                    android:layout_marginBottom="5dp"
                    android:layout_height="36dp" app:tint="#FFF"/>

            <TextView
                    android:text="Главная"
                    android:textColor="#FFF"
                    android:textSize="12sp"
                    android:layout_marginTop="-10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

        </LinearLayout>

        <LinearLayout
                android:id="@+id/motion_layout_3"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"

                app:layout_constraintStart_toEndOf="@id/motion_layout_2"
                app:layout_constraintEnd_toStartOf="@id/motion_layout_4"

                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"

                android:layout_marginEnd="28dp">

            <ImageButton
                    android:id="@+id/list"
                    android:src="@drawable/ic_list"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    app:tint="#222"/>

            <TextView
                    android:text="Список дел"
                    android:textColor="#222"
                    android:textSize="12sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

        </LinearLayout>

        <LinearLayout
                android:id="@+id/motion_layout_4"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"

                app:layout_constraintStart_toEndOf="@id/motion_layout_3"
                app:layout_constraintEnd_toEndOf="parent"

                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

            <ImageButton
                    android:id="@+id/profile"
                    android:src="@drawable/ic_profile"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="#222"
                    android:layout_width="40dp"
                    android:layout_height="40dp"/>

            <TextView
                    android:text="Профиль"
                    android:textColor="#222"
                    android:textSize="12sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

        </LinearLayout>

    </androidx.constraintlayout.motion.widget.MotionLayout>

</androidx.constraintlayout.widget.ConstraintLayout>